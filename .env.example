# ===========================================
# Giscus Configuration (Public - safe to expose)
# ===========================================
# How to obtain:
# 1) Navigate to https://giscus.app
# 2) Select your repo and discussion category
# 3) Copy the generated values for repoId and categoryId

NEXT_PUBLIC_GISCUS_REPO=<owner>/<repo>
NEXT_PUBLIC_GISCUS_REPO_ID=<repo_id>
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=<category_id>

# ===========================================
# App URL
# ===========================================

NEXT_PUBLIC_APP_URL=http://localhost:3003

# ===========================================
# Auth.js (GitHub OAuth)
# ===========================================
# Obtain from: https://github.com/settings/developers > OAuth Apps
# Authorization callback URL: <APP_URL>/api/auth/callback/github

AUTH_URL=http://localhost:3003/
AUTH_GITHUB_ID=<github_oauth_client_id>
AUTH_GITHUB_SECRET=<github_oauth_client_secret>
AUTH_SECRET=<random_secret_32_chars_or_more>

# Only this GitHub username is allowed to log in to Studio
ALLOWED_GITHUB_USERNAME=<your_github_username>

# ===========================================
# GitHub Auto Commit (Octokit)
# ===========================================
# Token requires push permission to the repository

GITHUB_OWNER=<owner>
GITHUB_REPO=<repo>
GITHUB_BRANCH=<branch>
GITHUB_TOKEN=<github_personal_access_token>

# ===========================================
# OpenAI (Translation)
# ===========================================

OPENAI_API_KEY=<openai_api_key>
# Optional: translation model (default: gpt-5-mini)
OPENAI_MDX_MODEL=gpt-5-mini
# Optional: blog Q&A model (default fallback: OPENAI_MDX_MODEL -> gpt-5.4-mini)
OPENAI_BLOG_CHAT_MODEL=gpt-5.4-mini

# ===========================================
# Blog Q&A Search (Optional)
# ===========================================

# Number of section matches to send to the model
BLOG_CHAT_SEARCH_TOP_K=3
# Minimum lexical score required before calling the model
BLOG_CHAT_SEARCH_MINIMUM_SCORE=6
# Maximum number of characters allowed in a single question
BLOG_CHAT_MAXIMUM_QUESTION_CHARACTERS=200
# Maximum total chat requests allowed per day (KST), in-memory only
BLOG_CHAT_MAXIMUM_DAILY_REQUESTS=100
# Response cache TTL in milliseconds
BLOG_CHAT_CACHE_TTL_MS=300000

# ===========================================
# MDX i18n Script Defaults (Optional)
# ===========================================

MDX_I18N_SOURCE=ko
MDX_I18N_TARGETS=ko,en

# ===========================================
# PDF Generation (Optional)
# ===========================================

# Cache directory for generated PDFs
RESUME_PDF_CACHE_DIR=.next/cache/resume-pdf
# TTL in milliseconds (default: infinite cache)
# RESUME_PDF_CACHE_TTL=86400000
# Port for temporary PDF server during build
PDF_SERVER_PORT=3005
# Custom Playwright executable path (optional)
# PLAYWRIGHT_EXECUTABLE_PATH=/path/to/chromium

# ===========================================
# AI Image Generation - LeesField API (Optional)
# ===========================================

LEESFIELD_API_KEY=<leesfield_api_key>
